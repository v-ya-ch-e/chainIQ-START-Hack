# Public ingress (nginx service)
PUBLIC_HTTP_PORT=80

# Preferred setup on AWS: RDS/MySQL endpoint
DB_HOST=your-rds-endpoint.rds.amazonaws.com
DB_PORT=3306
DB_USER=admin
DB_PASSWORD=replace-me
DB_NAME=chainiq

# Optional local MySQL profile values (used only with --profile localdb)
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=chainiq
MYSQL_USER=chainiq
MYSQL_PASSWORD=chainiq
